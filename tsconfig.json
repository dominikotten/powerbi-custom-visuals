{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "experimentalDecorators": true,
    "lib": [
      "es2015",
      "dom"
    ],
    "moduleResolution": "node",
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "outDir": "./.tmp/build/",
    "sourceMap": true,
    "strictNullChecks": true,
    "target": "ES6",
    "typeRoots": [
      "./node_modules/@types"
    ]
  },
  "files": [
    "./src/visual.ts"
  ]
}
