{
    "rules": {
        "comment-format": [true, "check-space"],
        "eofline": true,
        "import-blacklist": [true, "lodash"],
        "no-duplicate-imports": true,
        "no-unused-expression": true,
        "semicolon": [true, "always"],
        "trailing-comma": [true, {
            "singleline": "never",
            "multiline": "never"
        }]
    }
}
